{
  "dashboard": {
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "panels": [
      {
        "title": "Throughput: TPM (Tokens Per Minute) per Key",
        "type": "timeseries",
        "datasource": { "uid": "${datasource}" },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(litellm_total_tokens_metric[1m])) by (api_key_alias) * 60",
            "legendFormat": "Key: {{api_key_alias}}"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "reqps" } }
      },
      {
        "title": "Requests: RPM (Requests Per Minute) per Key",
        "type": "timeseries",
        "datasource": { "uid": "${datasource}" },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(litellm_proxy_total_requests_metric[1m])) by (api_key_alias) * 60",
            "legendFormat": "Key: {{api_key_alias}}"
          }
        ]
      },
      {
        "title": "Token Distribution: Input vs Output (Total)",
        "type": "barchart",
        "datasource": { "uid": "${datasource}" },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "sum(increase(litellm_input_tokens_metric[1h])) by (model)",
            "legendFormat": "Input: {{model}}"
          },
          {
            "expr": "sum(increase(litellm_output_tokens_metric[1h])) by (model)",
            "legendFormat": "Output: {{model}}"
          }
        ]
      },
      {
        "title": "Remaining Quota: RPM/TPM Limits per Key",
        "type": "gauge",
        "datasource": { "uid": "${datasource}" },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "litellm_remaining_api_key_requests_for_model",
            "legendFormat": "Rem. RPM: {{api_key_alias}} ({{model}})"
          },
          {
            "expr": "litellm_remaining_api_key_tokens_for_model",
            "legendFormat": "Rem. TPM: {{api_key_alias}} ({{model}})"
          }
        ]
      },
      {
        "title": "Real-time Queue Depth (In-Flight)",
        "type": "timeseries",
        "datasource": { "uid": "${datasource}" },
        "gridPos": { "h": 6, "w": 24, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "sum(litellm_in_flight_requests)",
            "legendFormat": "Current Active Requests"
          }
        ]
      }
    ],
    "refresh": "10s",
    "schemaVersion": 38,
    "title": "LiteLLM Performance - RPM/TPM Focus",
    "uid": "litellm-perf-key-metrics"
  }
}
